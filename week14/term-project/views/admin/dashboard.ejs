<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lava Birds B&B Admin Dashboard</title>
  <link rel="stylesheet" href="/admin.css">
</head>
<body class="admin-body">
  <%- include("../partials/admin-header", { user: user }) %>

  <main class="admin-shell dashboard-shell">
    <section class="admin-card dashboard-card">
      <header class="dashboard-header">
        <div class="brand-block">
          <img src="/assets/logo.png" alt="Lava Birds B&B logo" class="brand-logo">
          <div>
            <p class="eyebrow">Protected Admin Dashboard</p>
            <h1>Lava Birds B&B</h1>
          </div>
        </div>

        <a href="/admin/logout" class="logout-link">Logout</a>
      </header>

      <section class="welcome-panel">
        <h2>Welcome, <%= user.email %></h2>
        <p>
          You are signed in as the property admin for Lava Birds B&B.
        </p>
      </section>

      <% if (success) { %>
        <div class="alert success-alert" role="status">
          Special offer updated successfully.
        </div>
      <% } %>

      <section class="stats-grid" aria-label="Admin summary">
        <article class="stat-card">
          <span class="stat-label">Logged-in Admin</span>
          <strong><%= user.email %></strong>
        </article>

        <article class="stat-card">
          <span class="stat-label">Property Count</span>
          <strong><%= properties.length %></strong>
        </article>

        <article class="stat-card">
          <span class="stat-label">Total Guest Reviews</span>
          <strong><%= totalReviews %></strong>
        </article>

        <article class="stat-card review-action-card">
          <span class="stat-label">Guest Feedback</span>
          <button type="button" class="admin-button" id="open-reviews-modal">
            View Reviews
          </button>
        </article>
      </section>

      <% if (primaryProperty) { %>
        <section class="editor-section">
          <div class="section-heading">
            <h3>Update Marketing Page Special Offer</h3>
            <p>Edit the special offer content shown on the public Lava Birds B&B marketing page.</p>
          </div>

          <form method="POST" action="/admin/special-offer" class="admin-form offer-form">
            <div class="form-group">
              <label for="specialOffer">Special Offer Title</label>
              <input
                id="specialOffer"
                name="specialOffer"
                type="text"
                value="<%= primaryProperty.specialOffer || "" %>"
                required
              >
            </div>

            <div class="form-group">
              <label for="specialOfferDetails">Special Offer Details</label>
              <textarea
                id="specialOfferDetails"
                name="specialOfferDetails"
                rows="5"
                required
              ><%= primaryProperty.specialOfferDetails || "" %></textarea>
            </div>

            <button type="submit" class="admin-button save-button">Save Special Offer</button>
          </form>
        </section>

        <section class="table-section contact-messages-section">
          <div class="section-heading">
            <h3>Contact Messages</h3>
            <p>Messages submitted from the public contact popup appear here for admins only.</p>
          </div>

          <% if (!contactMessages.length) { %>
            <p class="empty-state">No contact messages have been submitted yet.</p>
          <% } else { %>
            <form
              method="POST"
              action="/admin/contact-messages/delete-selected"
              onsubmit="return confirm('Delete selected contact messages?');"
            >
              <div class="table-wrapper">
                <table class="admin-table">
                  <thead>
                    <tr>
                      <th>Select</th>
                      <th>Name</th>
                      <th>Email</th>
                      <th>Message</th>
                      <th>Submitted</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% contactMessages.forEach(function(contact) { %>
                      <tr>
                        <td>
                          <input
                            type="checkbox"
                            name="messageIds"
                            value="<%= contact._id %>"
                          >
                        </td>
                        <td><%= contact.name %></td>
                        <td><%= contact.email %></td>
                        <td><%= contact.message %></td>
                        <td><%= new Date(contact.createdAt).toLocaleString() %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>

              <div class="contact-message-actions">
                <button type="submit" class="admin-button clear-button">
                  Delete Selected
                </button>
              </div>
            </form>
          <% } %>
        </section>

      <% } %>

      <section class="table-section">
        <div class="section-heading">
          <h3>Property Records</h3>
          <p>Live Property Documents.</p>
        </div>

        <% if (!properties.length) { %>
          <p class="empty-state">No property records were found.</p>
        <% } else { %>
          <div class="table-wrapper">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Property</th>
                  <th>Island</th>
                  <th>Type</th>
                  <th>Contact Email</th>
                  <th>Reviews</th>
                  <th>Average Rating</th>
                </tr>
              </thead>
              <tbody>
                <% properties.forEach(function(property) { %>
                  <tr>
                    <td><%= property.name %></td>
                    <td><%= property.island %></td>
                    <td><%= property.type %></td>
                    <td><%= property.contactEmail || "N/A" %></td>
                    <td><%= property.reviewCount %></td>
                    <td><%= property.computedAverageRating.toFixed(1) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>
      <div id="reviews-modal" class="dashboard-modal hidden" role="dialog" aria-modal="true" aria-labelledby="reviews-modal-title">
        <div class="dashboard-modal-content">
          <button
            type="button"
            class="dashboard-modal-close"
            id="close-reviews-modal"
            aria-label="Close reviews popup"
          >
            ×
          </button>

          <h3 id="reviews-modal-title">Guest Reviews</h3>

          <% if (primaryProperty && primaryProperty.reviews && primaryProperty.reviews.length) { %>
            <ul class="admin-review-list">
              <% primaryProperty.reviews.slice().reverse().forEach(function(review) { %>
                <li class="admin-review-item">
                  <div class="admin-review-head">
                    <strong><%= review.guestName %></strong>
                    <span><%= Number(review.rating || 0).toFixed(1) %> / 5</span>
                  </div>
                  <p><%= review.comment || "No written comment provided." %></p>
                </li>
              <% }) %>
            </ul>
          <% } else { %>
            <p>No reviews available yet.</p>
          <% } %>
        </div>
      </div>
      <script>
        const openReviewsModalButton = document.getElementById("open-reviews-modal");
        const closeReviewsModalButton = document.getElementById("close-reviews-modal");
        const reviewsModal = document.getElementById("reviews-modal");

        if (openReviewsModalButton && closeReviewsModalButton && reviewsModal) {
          openReviewsModalButton.addEventListener("click", () => {
            reviewsModal.classList.remove("hidden");
          });

          closeReviewsModalButton.addEventListener("click", () => {
            reviewsModal.classList.add("hidden");
          });

          reviewsModal.addEventListener("click", (event) => {
            if (event.target === reviewsModal) {
              reviewsModal.classList.add("hidden");
            }
          });
        }
      </script>

    </section>
  </main>
</body>
</html>
