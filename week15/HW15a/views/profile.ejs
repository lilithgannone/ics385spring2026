<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Profile</title>
</head>
<body>
  <main>
    <h1>Profile</h1>

    <p><strong>Email:</strong> <%= user.email %></p>
    <p><strong>Display Name:</strong> <%= user.displayName %></p>
    <p><strong>Mongoose ID:</strong> <%= user._id %></p>

    <form action="/logout" method="POST">
      <button type="submit">Log out</button>
    </form>
  </main>
</body>
</html>
